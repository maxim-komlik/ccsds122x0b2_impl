<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <ProjectRuntimeWorkdir>$(RepositoryOutputDir)runtime\workdir\$(ProjectName)\</ProjectRuntimeWorkdir>
  </PropertyGroup>
  <PropertyGroup />
  <ItemDefinitionGroup />
  <ItemGroup>
    <BuildMacro Include="ProjectRuntimeWorkdir">
      <Value>$(ProjectRuntimeWorkdir)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>