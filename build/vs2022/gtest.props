<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <RepositoryOutputDir>$(SolutionDir)..\out\</RepositoryOutputDir>
    <TestOutputDir>$(SolutionDir)out\$(ProjectName)\</TestOutputDir>
    <TestIntDir>$(RepositoryOutputDir)obj\</TestIntDir>
    <TargetOutputDir>$(RepositoryOutputDir).\$(Platform)\$(Configuration)\</TargetOutputDir>
    <DebugRuntimeWorkingDir>$(RepositoryOutputDir)runtime\workdir\</DebugRuntimeWorkingDir>
  </PropertyGroup>
  <PropertyGroup>
    <OutDir>$(TestOutputDir)$(Platform)\$(Configuration)\</OutDir>
    <IncludePath>$(ProjectDir);$(IncludePath)</IncludePath>
    <IntDir>$(TestIntDir)$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="RepositoryOutputDir">
      <Value>$(RepositoryOutputDir)</Value>
    </BuildMacro>
    <BuildMacro Include="TestOutputDir">
      <Value>$(TestOutputDir)</Value>
    </BuildMacro>
    <BuildMacro Include="TestIntDir">
      <Value>$(TestIntDir)</Value>
    </BuildMacro>
    <BuildMacro Include="TargetOutputDir">
      <Value>$(TargetOutputDir)</Value>
    </BuildMacro>
    <BuildMacro Include="DebugRuntimeWorkingDir">
      <Value>$(DebugRuntimeWorkingDir)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>